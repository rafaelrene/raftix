#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"

PROFILE=raftix
INIT=openrc
WORKSPACE="${ARTOOLS_WORKSPACE:-/var/lib/artools}"
ISO_PROFILES="$WORKSPACE/iso-profiles"
PROFILE_DIR="$ISO_PROFILES/$PROFILE"

require_linux() {
	[[ "$(uname -s)" == Linux ]] || die "Artix buildiso must run on Linux"
}

prepare_workspace() {
	require_cmd buildiso
	require_cmd findmnt
	require_cmd git
	require_cmd yq
	local fstype
	fstype="$(findmnt -no FSTYPE -T "$WORKSPACE" 2>/dev/null || true)"
	case "$fstype" in
	overlay | tmpfs | squashfs)
		die "$WORKSPACE is on $fstype; buildiso needs an ext4/xfs/btrfs-backed writable filesystem"
		;;
	esac

	mkdir -p "$WORKSPACE"

	if [[ ! -d "$ISO_PROFILES/.git" ]]; then
		git clone https://gitea.artixlinux.org/artix/iso-profiles.git "$ISO_PROFILES"
	fi

	git -C "$ISO_PROFILES" fetch origin
	git -C "$ISO_PROFILES" checkout wip
	git -C "$ISO_PROFILES" pull --ff-only

	rm -rf "$PROFILE_DIR"
	cp -a "$ISO_PROFILES/base" "$PROFILE_DIR"
}

install_overlay() {
	local overlay="$PROFILE_DIR/root-overlay"
	mkdir -p "$overlay/usr/local/bin" "$overlay/usr/local/share/raftix" "$overlay/root"
	copy_exec "$REPO_ROOT/scripts/raftix-install" "$overlay/usr/local/bin/raftix-install"
	copy_exec "$REPO_ROOT/scripts/raftix" "$overlay/usr/local/bin/raftix"
	cp -a "$REPO_ROOT/scripts/lib" "$overlay/usr/local/bin/lib"
	cp -a "$REPO_ROOT/share/raftix/." "$overlay/usr/local/share/raftix/"
	cp -a "$REPO_ROOT/wallpapers" "$overlay/usr/local/share/raftix/wallpapers"
	printf 'RAFTIX_SHARE_DIR=/usr/local/share/raftix raftix-install\n' >"$overlay/root/.zlogin"
	printf 'RAFTIX_SHARE_DIR=/usr/local/share/raftix raftix-install\n' >"$overlay/root/.bash_profile"
}

install_live_packages() {
	local profile_yaml="$PROFILE_DIR/profile.yaml"
	local package

	while read -r package; do
		[[ -n "$package" ]] || continue
		yq -i ".rootfs.packages += [\"$package\"] | .rootfs.packages |= unique" "$profile_yaml"
	done <"$REPO_ROOT/share/raftix/packages/iso-live.txt"
}

build_iso() {
	WORKSPACE_DIR="$WORKSPACE" buildiso \
		-p "$PROFILE" \
		-i "$INIT" \
		-r "$WORKSPACE/buildiso" \
		-t "$WORKSPACE/iso"
	local iso
	iso="$(find "$WORKSPACE/iso" -type f -name '*.iso' | sort | tail -n 1)"
	[[ -n "$iso" ]] || die "ISO not found"
	local date_name
	date_name="raftix-$(date +%Y.%m.%d)-x86_64.iso"
	mkdir -p "$REPO_ROOT/dist"
	cp "$iso" "$REPO_ROOT/dist/$date_name"
	(cd "$REPO_ROOT/dist" && sha256sum "$date_name" >"$date_name.sha256")
	log "built dist/$date_name"
}

main() {
	require_linux
	prepare_workspace
	install_overlay
	install_live_packages
	build_iso
}

main "$@"
